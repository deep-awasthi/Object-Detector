{
  "name": "devatlas",
  "version": "1.0.0",
  "private": true,
  "description": "DevAtlas - Crafting knowledge for engineers",
  "scripts": {
    "setup": "bash setup.sh",
    "dev": "next dev",
    "dev:test": "next dev --port 3456 & sleep 5 && node scripts/flow-test.js; kill %1 2>/dev/null",
    "build": "next build && pnpm test:all",
    "start": "next start",
    "perf": "node scripts/perf-test.js",
    "security": "node scripts/security-test.js",
    "flows": "node scripts/flow-test.js",
    "flows:admin": "node scripts/flow-test.js --admin",
    "test": "pnpm test:all",
    "test:all": "pnpm perf && pnpm security && pnpm flows",
    "test:perf": "pnpm perf",
    "test:security": "pnpm security",
    "test:flows": "pnpm flows",
    "test:flows:admin": "pnpm flows:admin",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@lexical/react": "^0.21.0",
    "@lexical/utils": "^0.21.0",
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.60.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.0",
    "dompurify": "^3.2.0",
    "framer-motion": "^11.12.0",
    "jose": "^5.9.0",
    "lexical": "^0.21.0",
    "lucide-react": "^0.460.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "shiki": "^1.24.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
